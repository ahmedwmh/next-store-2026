# --- Database (Supabase PostgreSQL) ---
# Pooled connection for Prisma at runtime on Vercel (often port 6543, add ?pgbouncer=true per Supabase docs)
DATABASE_URL=
# Direct URL for migrations / prisma generate (port 5432)
DIRECT_URL=

# --- Clerk (https://dashboard.clerk.com) ---
# Use Production keys on Vercel; add your deployment domain under Clerk → Domains
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Supabase Storage (property images) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
BUCKET_NAME=
